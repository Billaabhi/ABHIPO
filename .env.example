# Jira Integration Configuration
# Copy this file to .env.local and .env.production, then add your actual values

# Jira Cloud Instance URL
# Get from: https://your-domain.atlassian.net
JIRA_INSTANCE=https://ebdae.atlassian.net

# Jira API Token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
# Format: your-email@domain.com and your-api-token
JIRA_TOKEN=your_api_token_here

# Cache TTL (time-to-live) in seconds
# Default: 900 (15 minutes)
# Lower values = more API calls but fresher data
# Higher values = fewer API calls but potentially stale data
CACHE_TTL=900

# Webhook secret (for future HMAC verification)
# Optional: helps verify Jira webhooks are authentic
WEBHOOK_SECRET=your_webhook_secret_here

# Server port (for local development)
# Ignored in Vercel (uses serverless)
PORT=3000

# Environment
NODE_ENV=production
